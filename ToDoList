from fastapi import FastAPI, HTTPException, status
from pydantic import BaseModel
from typing import List, Optional
from enum import Enum

# Create FastAPI application
app = FastAPI(
    title="To-Do List API",
    version="1.0.0",
    description="A simple API for managing todo items",
    docs_url="/docs",
    redoc_url="/redoc"
)

# In-memory storage (temporary, replace with database in production)
todos = []
next_id = 1

# Data models
class TodoStatus(str, Enum):
    PENDING = "pending"
    COMPLETED = "completed"
    IN_PROGRESS = "in_progress"

class TodoCreate(BaseModel):
    title: str
    description: Optional[str] = None
    status: TodoStatus = TodoStatus.PENDING

class TodoUpdate(BaseModel):
    title: Optional[str] = None
    description: Optional[str] = None
    status: Optional[TodoStatus] = None

class TodoResponse(TodoCreate):
    id: int
    
    class Config:
        orm_mode = True
        use_enum_values = True

# Helper function to find todo by ID
def find_todo_by_id(todo_id: int) -> Optional[dict]:
    for todo in todos:
        if todo["id"] == todo_id:
            return todo
    return None

def find_todo_index(todo_id: int) -> Optional[int]:
    for index, todo in enumerate(todos):
        if todo["id"] == todo_id:
            return index
    return None

# Home endpoint
@app.get("/", tags=["Root"])
async def read_root():
    return {
        "message": "به API مدیریت کارهای روزانه خوش آمدید!",
        "version": app.version,
        "docs": "/docs",
        "endpoints": {
            "GET /todos": "Get all todos",
            "GET /todos/{id}": "Get a specific todo",
            "POST /todos": "Create a new todo",
            "PUT /todos/{id}": "Update a todo",
            "DELETE /todos/{id}": "Delete a todo",
            "PATCH /todos/{id}/status": "Update todo status"
        }
    }

# Health check endpoint
@app.get("/health", tags=["Health"])
async def health_check():
    return {"status": "healthy", "timestamp": "current_time"}

# Create new todo
@app.post(
    "/todos",
    response_model=TodoResponse,
    status_code=status.HTTP_201_CREATED,
    tags=["Todos"]
)
async def create_todo(todo: TodoCreate):
    global next_id
    
    new_todo = {
        "id": next_id,
        "title": todo.title,
        "description": todo.description,
        "status": todo.status.value
    }
    
    todos.append(new_todo)
    next_id += 1
    
    return new_todo

# Get all todos with optional filtering
@app.get("/todos", response_model=List[TodoResponse], tags=["Todos"])
async def get_all_todos(status: Optional[TodoStatus] = None):
    if status:
        filtered_todos = [todo for todo in todos if todo["status"] == status.value]
        return filtered_todos
    return todos

# Get specific todo
@app.get("/todos/{todo_id}", response_model=TodoResponse, tags=["Todos"])
async def get_todo(todo_id: int):
    todo = find_todo_by_id(todo_id)
    if not todo:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="کار مورد نظر یافت نشد"
        )
    return todo

# Update todo
@app.put("/todos/{todo_id}", response_model=TodoResponse, tags=["Todos"])
async def update_todo(todo_id: int, todo_update: TodoUpdate):
    todo = find_todo_by_id(todo_id)
    if not todo:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="کار مورد نظر یافت نشد"
        )
    
    # Update fields if provided
    update_data = todo_update.dict(exclude_unset=True)
    for field, value in update_data.items():
        todo[field] = value
    
    return todo

# Update todo status
@app.patch("/todos/{todo_id}/status", response_model=TodoResponse, tags=["Todos"])
async def update_todo_status(todo_id: int, status: TodoStatus):
    todo = find_todo_by_id(todo_id)
    if not todo:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="کار مورد نظر یافت نشد"
        )
    
    todo["status"] = status.value
    return todo

# Delete todo
@app.delete("/todos/{todo_id}", tags=["Todos"])
async def delete_todo(todo_id: int):
    todo_index = find_todo_index(todo_id)
    if todo_index is None:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="کار مورد نظر یافت نشد"
        )
    
    deleted_todo = todos.pop(todo_index)
    return {
        "message": "کار با موفقیت حذف شد",
        "deleted_todo": deleted_todo
    }

# Get todos count
@app.get("/todos/statistics/summary", tags=["Statistics"])
async def get_todos_summary():
    total = len(todos)
    completed = sum(1 for todo in todos if todo["status"] == "completed")
    pending = sum(1 for todo in todos if todo["status"] == "pending")
    in_progress = sum(1 for todo in todos if todo["status"] == "in_progress")
    
    return {
        "total_todos": total,
        "completed": completed,
        "pending": pending,
        "in_progress": in_progress,
        "completion_rate": (completed / total * 100) if total > 0 else 0
    }